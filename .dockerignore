# ╔═══════════════════════════════════════════════════════════════════════╗
# ║  .dockerignore - Appwrite Security Analysis                           ║
# ║  Docker imajına dahil edilMEYECEK dosyalar                           ║
# ╚═══════════════════════════════════════════════════════════════════════╝

# Git dosyaları
.git
.gitignore
.github

# Dokümantasyon (imajda gereksiz)
*.md
!README.md
LICENSE

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
.venv/
env/

# IDE dosyaları
.vscode/
.idea/
*.swp
*.swo

# OS dosyaları
.DS_Store
Thumbs.db

# Log ve sonuç dosyaları (runtime'da oluşturulur)
logs/
results/
screenshots/

# Docker dosyaları (recursive build engellenir)
docker-compose.yml
Dockerfile
.dockerignore
