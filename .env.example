# ╔══════════════════════════════════════════════════════════════════════╗
# ║  .env.example — Appwrite Security Analysis                          ║
# ║                                                                     ║
# ║  KULLANIM: Bu dosyayı .env olarak kopyalayın ve değerleri doldurun ║
# ║    cp .env.example .env                                             ║
# ║                                                                     ║
# ║  UYARI: Gerçek kimlik bilgilerini bu dosyaya YAZMAYIN!             ║
# ║  .env dosyası .gitignore ile korunuyor ve repoya girmez.           ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Appwrite Bağlantı Ayarları ──────────────────────────────────────────
# Appwrite sunucu adresi (lokal kurulum için: http://localhost/v1)
APPWRITE_ENDPOINT=http://localhost/v1

# Appwrite proje ID'niz (Appwrite konsolundan alınır)
APPWRITE_PROJECT_ID=your-project-id-here

# Appwrite API anahtarı (opsiyonel — yalnızca sunucu taraflı testler için)
APPWRITE_API_KEY=your-api-key-here

# ── Test Hesabı Yapılandırması ───────────────────────────────────────────
# PoC testlerinde kullanılacak "saldırgan" hesabı
ATTACKER_EMAIL=attacker@yourdomain.com
ATTACKER_PASSWORD=change-this-strong-password

# PoC testlerinde kullanılacak "mağdur" hesabı
VICTIM_EMAIL=victim@yourdomain.com
VICTIM_PASSWORD=change-this-strong-password

# Test için hedef kullanıcı ID'si (opsiyonel)
TARGET_USER_ID=

# ── Veritabanı Yapılandırması ────────────────────────────────────────────
# Analiz edilecek veritabanı ve koleksiyon
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_COLLECTION_ID=your-collection-id

# ── Genel Ayarlar ────────────────────────────────────────────────────────
# Debug modu: production'da false yapın
DEBUG=false

# Sonuçları dosyaya kaydet: true / false
SAVE_RESULTS=true

# Çıktı formatı: json / text
OUTPUT_FORMAT=json
