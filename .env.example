# Copy to .env before use.
# Never commit real secrets.

APPWRITE_ENDPOINT=http://appwrite:80/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=replace-with-temporary-dev-key
APPWRITE_DATABASE_ID=sample-db
APPWRITE_COLLECTION_ID=sample-collection
APPWRITE_VICTIM_DOCUMENT_ID=sample-document-id
APPWRITE_TIMEOUT=15
APPWRITE_VERIFY_TLS=false
LOG_LEVEL=INFO
